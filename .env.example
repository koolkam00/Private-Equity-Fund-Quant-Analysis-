# Flask runtime
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-secret

# Database
# Render will inject DATABASE_URL automatically in production.
# For local production-like runs, set DATABASE_URL manually.
DATABASE_URL=postgresql://username:password@hostname:5432/database_name
# Optional override (if you prefer this key instead of DATABASE_URL):
# SQLALCHEMY_DATABASE_URI=postgresql://username:password@hostname:5432/database_name

# Bootstrap admin account
# Required only when the users table is empty on first startup.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_TEAM_NAME=Admin Team

# Optional runtime override
PORT=5001
